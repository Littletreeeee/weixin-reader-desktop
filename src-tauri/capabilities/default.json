{
  "$schema": "../gen/schemas/remote-schema.json",
  "identifier": "default",
  "description": "Capability for the main window with remote domain access",
  "windows": ["main", "settings", "privacy", "terms"],
  "remote": {
    "urls": [
      "https://weread.qq.com/*",
      "https://*.weread.qq.com/*",
      "http://localhost.weixin.qq.com:*"
    ]
  },
  "permissions": [
    "core:default",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "store:default",
    "window-state:default",
    "log:default",
    "shell:allow-open",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-size",
    "core:window:allow-create",
    "updater:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://weread.qq.com/*" },
        { "url": "https://*.weread.qq.com/*" }
      ]
    }
  ]
}
